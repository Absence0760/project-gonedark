{
  "name": "project-gonedark",
  "version": "0.0.0",
  "private": true,
  "description": "Going Dark — convenience task runner for the Rust engine and local dev services. The game IS Rust/cargo (see CLAUDE.md); this package.json only wraps cargo / cargo-ndk+Gradle+adb / docker compose behind named commands, not as a JS build. No dependencies — `pnpm install` is unnecessary. Scripts are namespaced by the device/target they hit: `desktop:*` (this machine), `android:*` (a phone over adb), `services:*` (local Docker). Run `pnpm help` for descriptions.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "help": "bash scripts/help.sh",

    "play": "cargo run -p gonedark-app --release",
    "play:debug": "cargo run -p gonedark-app",
    "play:audio": "cargo run -p gonedark-app --release --features audio",
    "desktop:build": "cargo build --workspace",
    "desktop:build:release": "cargo build --workspace --release",
    "desktop:sim": "cargo run -p gonedark-sim-runner",
    "desktop:sim:stress": "cargo run -p gonedark-sim-runner --release -- 300 stress --time",
    "desktop:sim:combat": "cargo run -p gonedark-sim-runner -- 300 infantry",
    "desktop:sim:matchup": "cargo run -p gonedark-sim-runner -- 300 matchup",
    "desktop:sim:net": "cargo run -p gonedark-net-sim-runner",
    "desktop:replay": "cargo run -p gonedark-replay-runner",
    "desktop:viz": "cargo run -p gonedark-viz-runner",
    "desktop:server": "cargo run -p gonedark-server",

    "android:devices": "scripts/android.sh devices",
    "android:setup": "scripts/android.sh setup",
    "android:build": "scripts/android.sh build",
    "android:apk": "scripts/android.sh apk",
    "android:install": "scripts/android.sh install",
    "android:dev": "scripts/android.sh run",
    "android:logcat": "scripts/android.sh logcat",
    "android:checksum": "scripts/android-checksum.sh",
    "android:stress": "scripts/android-stress.sh",
    "android:fps": "scripts/android-fps.sh",

    "assets:models": "blender --background --python tools/models/gen_models.py",
    "assets:rig": "blender --background --python tools/models/gen_trooper_rig.py",
    "assets:font": "python3 tools/fonts/gen_hud_font.py",
    "assets:textures": "python3 tools/textures/gen_textures.py",
    "assets:icons": "python3 tools/icons/gen_icons.py",
    "assets:app-icon": "python3 tools/icons/gen_app_icon.py",
    "assets:maps": "python3 tools/maps/ingest.py --all && python3 tools/maps/bake.py --all --verify",
    "maps:lint": "python3 tools/maps/lint.py --all",

    "test": "cargo test --workspace --exclude gonedark-pal-android",
    "lint": "cargo clippy --workspace --exclude gonedark-pal-android -- -D warnings",
    "fmt": "cargo fmt",

    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:restart": "docker compose restart",
    "services:status": "docker compose ps",
    "services:logs": "docker compose logs -f",
    "services:reset": "docker compose down -v",
    "services:db": "docker compose up -d postgres",
    "services:redis": "docker compose up -d redis"
  }
}
