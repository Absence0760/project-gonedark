# Build output
/out/
*.apk
*.aab

# Android / Gradle
.gradle/
local.properties
/app/build/
/android/app/build/
*.iml
# cargo-ndk output — the native .so is rebuilt into the Gradle project on demand
# (see android/README.md); it's a build artifact, never committed.
/android/app/src/main/jniLibs/

# Rust (engine language — decisions.md D10)
/target/

# Node — root package.json is only a pnpm task-runner for docker compose (no deps),
# so there is nothing to lock or vendor; ignore an accidental install.
node_modules/

# IDE / editor
.idea/
.vscode/
*.swp
*~

# OS
.DS_Store
Thumbs.db

# Claude Code — personal/local settings (project settings.json IS checked in)
.claude/settings.local.json
# Python bytecode from running the hook tests (e.g. git-scope-guard.test.py)
.claude/hooks/__pycache__/
*.pyc

# Env — .env.development IS committed (safe defaults); local/secret variants are not
.env.local
.env*.local
.env.production
.env.prod

# Terraform
infra/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan
*.auto.tfvars
crash.log
crash.*.log
override.tf
override.tf.json

# NOTE: production secrets do NOT live in this repo. They are sops/KMS-encrypted in the
# separate private estate repo (~/github/infra-secrets/gonedark/) so this potentially-
# public game repo never ships ciphertext. See decision D12 / docs/infrastructure.md.

# Cooked assets (regenerated by the offline pipeline)
/assets/cooked/
*.pak
