{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(//home/jhoward/github/project-gonedark/**)",
      "Grep",
      "Glob",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git ls-files)",
      "Bash(git ls-files:*)",
      "Bash(git remote -v)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt --check:*)",
      "Bash(cargo fmt -- --check:*)",
      "Bash(cargo doc:*)",
      "Bash(terraform fmt -check:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform plan:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find . -name *)",
      "Bash(find . -path *)",
      "Bash(find . -type *)"
    ],
    "deny": [
      "Bash(git commit --no-verify)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(rm -rf /)",
      "Bash(sudo:*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)"
    ]
  },
  "worktree": {
    "baseRef": "head"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/unmerged-worktree-check.sh\"",
            "timeout": 10,
            "description": "Warns at session start if any branch holds commits not on main (e.g. a forgotten worktree branch), so worktree work always gets consolidated back to main. See .claude/hooks/unmerged-worktree-check.sh."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/git-scope-guard.py\"",
            "timeout": 10,
            "statusMessage": "Checking git scope"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-$PWD}/.claude/hooks/sim-determinism-guard.sh\"",
            "description": "Flags floats / transcendentals / nondeterministic iteration leaking into the fixed-point sim (CLAUDE.md invariants #1, #7). Inert until sim/core Rust code exists. See .claude/hooks/sim-determinism-guard.sh."
          }
        ]
      }
    ]
  }
}
