<?xml version="1.0" encoding="utf-8"?>
<!--
  Going Dark — app manifest.

  Two activities, the D32 native/in-engine app-shell split made concrete:

    * .MainActivity              — the Jetpack-Compose APP SHELL (LAUNCHER): the title / landing
                                   screen (D32 surface 1). Out-of-match chrome; holds no game state.
    * android.app.NativeActivity — the shared RUST ENGINE. `android.app.lib_name` names the cdylib
                                   (libgonedark_pal_android.so) WITHOUT the `lib` prefix or `.so`
                                   suffix; the platform's NativeActivity loads it and calls
                                   ANativeActivity_onCreate, which android-activity's
                                   `native-activity` feature wires to our exported `android_main`.
                                   Started by the shell on "Start"; NOT the launcher and not exported.

  `android:hasCode` is now the default (true) — the app carries Kotlin/Compose code. The lib_name
  must still match the cdylib cargo-ndk produces (crate `gonedark_pal_android` -> emits
  `libgonedark_pal_android.so`).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="Going Dark"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="true"
        android:theme="@style/Theme.GoingDark">

        <!-- The native Compose app shell: the screen the player lands on. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|density|uiMode"
            android:screenOrientation="landscape">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The shared Rust engine. Launched by MainActivity on "Start"; not the launcher. -->
        <activity
            android:name="android.app.NativeActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout|density|uiMode"
            android:screenOrientation="landscape">

            <!-- Name of the Rust cdylib (no `lib` prefix, no `.so`). -->
            <meta-data
                android:name="android.app.lib_name"
                android:value="gonedark_pal_android" />
        </activity>
    </application>
</manifest>
